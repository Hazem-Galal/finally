# Copy this file to .env and fill in values as needed.
# See planning/PLAN.md Section 5 for full behavior details.

# Required for AI chat functionality (OpenRouter API key).
# If unset, the rest of the app (market data, trading) still works;
# /api/chat returns an "AI chat unavailable" message instead of erroring.
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data.
# If unset, the built-in market simulator is used (recommended for most users).
MASSIVE_API_KEY=

# Optional: set to "true" for deterministic mock LLM responses (used in E2E tests).
LLM_MOCK=false
